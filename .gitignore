# === 依赖 / 构建产物 ===
node_modules/
dist/
out/
build/*
!build/icon.ico
release/
*.tsbuildinfo

# === 机密 / 本地配置(绝不入库)===
.env
.env.*
*.local
settings.local.json
**/secrets.json

# === Python(资产工具)===
__pycache__/
*.py[cod]
.venv/
venv/

# === 资产工具的生成产物(run 目录,非源码)===
output/
tools/hatch-desktop-pet/output/
tools/hatch-desktop-pet/**/decoded/
tools/hatch-desktop-pet/**/frames/

# === 运行时用户数据(应落在用户目录,不入库)===
/userdata/

# === 日志 / 系统 ===
*.log
.DS_Store
Thumbs.db

# === superpowers 工作流暂存(brainstorm 会话产物等,非源码)===
.superpowers/brainstorm/

